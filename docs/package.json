{
  "name": "@kahitsan/ksui-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Live documentation site for @kahitsan/ksui. Self contained Vite + SolidJS SPA; not part of the published package and not in the root tsconfig.",
