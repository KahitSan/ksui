    "lucide-solid": "^1.7.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "shiki": "^1.24.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-solid": "^2.11.0"
  }
}
