{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": []
  },
  // The library is standalone — it imports only solid-js + lucide-solid, so it
  // type-checks on its own. The authoritative gate is still each consuming
  // plugin's tsc (where lucide-solid + the consumer's solid are present).
  "include": ["src"]
}
